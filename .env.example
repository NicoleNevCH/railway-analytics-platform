# =====================================================================
# Railway Analytics Platform — environment variables
# Copy to .env (docker compose loads .env automatically):
#     cp .env.example .env
# =====================================================================

# --- MinIO / S3 credentials ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_REGION=us-east-1

# --- Lakehouse buckets / layers ---
BRONZE_BUCKET=bronze
SILVER_BUCKET=silver
ERRORS_BUCKET=errors

# --- Iceberg ---
# effective warehouse = s3://${SILVER_BUCKET}/warehouse
ICEBERG_NAMESPACE=railway
ICEBERG_TABLE=train_events

# --- Business rule: delay threshold (minutes) ---
# A delay strictly GREATER than this value => DELAYED.
DELAY_THRESHOLD_MIN=5

# --- Spark worker (resources) ---
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2

# --- Jupyter ---
JUPYTER_TOKEN=railway
